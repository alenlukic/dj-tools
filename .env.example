# Copy this file to .env and fill in your values.
# NEVER commit .env with real secrets — it is gitignored for this reason.

# Data paths
DATA_ROOT=/home/alen/Data/dj-tools/data
DATA_BACKUP_RESTORE_MUSIC_DIR=backup/restored
DATA_FILE_STAGING_DIR=file_staging

# Database
DB_NAME=music_collection
DB_USER=postgres
DB_PASSWORD=changeme
DB_HOST=localhost
DB_PORT=5432

# Feature extraction
FEATURE_EXTRACTION_SMMS_CACHE_SIZE=4096

# Harmonic mixing weights (must sum to 1.0)
HM_WEIGHT_SMMS_SCORE=0.24
HM_WEIGHT_CAMELOT=0.19
HM_WEIGHT_BPM=0.17
HM_WEIGHT_FRESHNESS=0.14
HM_WEIGHT_LABEL=0.12
HM_WEIGHT_GENRE=0.08
HM_WEIGHT_ARTIST=0.04
HM_WEIGHT_ENERGY=0.02

# Harmonic mixing thresholds
HM_3_SD_SMMS=525.294
HM_MAX_RESULTS=50
HM_SCORE_THRESHOLD=25
HM_RESULT_THRESHOLD=20

# Ingestion pipeline
INGESTION_PIPELINE_ROOT=/path/to/dj-tools/data/ingestion_pipeline
INGESTION_PIPELINE_UNPROCESSED=unprocessed
INGESTION_PIPELINE_PROCESSING=processing
INGESTION_PIPELINE_FINALIZED=finalized
INGESTION_PIPELINE_REKORDBOX_TAG_FILE=rekordbox_tags.txt
INGESTION_PIPELINE_PROCESSED_MUSIC_DIR=/path/to/Music/High Quality

# Track metadata module
TRACK_METADATA_DOWNLOAD_DIR=/path/to/Downloaded Tracks
TRACK_METADATA_PROCESSING_DIR=processing
TRACK_METADATA_AUGMENTED_DIR=augmented
TRACK_METADATA_LOG_DIR=logs

# Logging
LOG_LOCATION=logs/logs.txt

# Parallelism (default: CPU count)
# NUM_CORES=4
