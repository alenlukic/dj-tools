# Copy this file to .env and fill in your values.
# NEVER commit .env with real secrets — it is gitignored for this reason.

# ── Data paths ──────────────────────────────────────────────
DATA_ROOT=/path/to/dj-tools/data
DATA_BACKUP_RESTORE_MUSIC_DIR=backup/restored
DATA_FILE_STAGING_DIR=file_staging

# ── Database ────────────────────────────────────────────────
DB_NAME=music_collection
DB_USER=postgres
DB_PASSWORD=changeme
DB_HOST=localhost
DB_PORT=5432

# ── Harmonic mixing weights (must sum to 1.0) ──────────────
HM_WEIGHT_SIMILARITY=0.18
HM_WEIGHT_CAMELOT=0.20
HM_WEIGHT_BPM=0.20
HM_WEIGHT_FRESHNESS=0.08
HM_WEIGHT_GENRE_SIMILARITY=0.08
HM_WEIGHT_MOOD_CONTINUITY=0.06
HM_WEIGHT_DANCEABILITY=0.07
HM_WEIGHT_VOCAL_CLASH=0.05
HM_WEIGHT_ENERGY=0.04
HM_WEIGHT_TIMBRE=0.04
HM_WEIGHT_INSTRUMENT_SIMILARITY=0.02

# ── Harmonic mixing thresholds ──────────────────────────────
HM_MAX_RESULTS=50
HM_SCORE_THRESHOLD=25
HM_RESULT_THRESHOLD=20

# ── Ingestion pipeline ─────────────────────────────────────
INGESTION_PIPELINE_ROOT=/path/to/dj-tools/data/ingestion_pipeline
INGESTION_PIPELINE_UNPROCESSED=unprocessed
INGESTION_PIPELINE_PROCESSING=processing
INGESTION_PIPELINE_FINALIZED=finalized
INGESTION_PIPELINE_REKORDBOX_TAG_FILE=rekordbox_tags.txt
INGESTION_PIPELINE_PROCESSED_MUSIC_DIR=/path/to/Music/High Quality

# ── Track metadata module ──────────────────────────────────
TRACK_METADATA_DOWNLOAD_DIR=/path/to/Downloaded Tracks
TRACK_METADATA_PROCESSING_DIR=processing
TRACK_METADATA_AUGMENTED_DIR=augmented
TRACK_METADATA_LOG_DIR=logs
# TRACK_METADATA_RUN_START=20260101T000000  # override the per-run timestamp

# ── Logging ─────────────────────────────────────────────────
LOG_LOCATION=logs/logs.txt

# ── Parallelism ─────────────────────────────────────────────
# NUM_CORES=4                  # default: system CPU count

# ── Elasticsearch ───────────────────────────────────────────
ES_URL=http://127.0.0.1:9200
ES_TRACK_INDEX=dj_tracks

# ── Feature extraction workers ──────────────────────────────
# TRAIT_WORKERS=2              # parallel ONNX trait extraction workers
# COSINE_WORKERS=2             # parallel cosine similarity workers

# ── External API keys (optional) ────────────────────────────
# OPENAI_API_KEY=              # enables LLM metadata resolution
# OPENAI_METADATA_MODEL=gpt-5.4-mini
# ACOUSTID_API_KEY=            # enables AcoustID fingerprint lookup
# DISCOGS_TOKEN=               # enables Discogs metadata lookup
# MUSIC_METADATA_USER_AGENT=metadata-hydrator/1.0 (https://example.com/contact)
